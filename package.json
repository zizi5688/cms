{
  "name": "super-cms",
  "version": "1.0.6",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "rebuild": "electron-rebuild",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build:app": "npm run typecheck && electron-vite build",
    "build": "npm run build:app && electron-builder --config electron-builder.json",
    "dist": "npm run build:mac",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build:app && electron-builder --dir --config electron-builder.json",
    "build:win:engine": "powershell -ExecutionPolicy Bypass -File scripts/build-cms-engine-win.ps1",
    "prepare:win:deps": "powershell -ExecutionPolicy Bypass -File scripts/prepare-win-runtime-deps.ps1",
    "build:win:x64": "npm run build:app && electron-builder --win --x64 --config electron-builder.json --publish never",
    "verify:win:x64": "node scripts/verify-win-package.cjs release x64",
    "publish:win:x64": "node scripts/release-win-x64.cjs",
    "build:win": "npm run build:win:x64",
    "publish:win": "npm run publish:win:x64",
    "build:mac:engine": "bash scripts/build-cms-engine-mac.sh",
    "build:mac:verify-engine": "bash scripts/verify-cms-engine-mac.sh",
    "build:mac": "npm run build:mac:engine && npm run build:mac:verify-engine && npm run build:app && electron-builder --mac --config electron-builder.json",
    "build:linux": "npm run build:app && electron-builder --linux --config electron-builder.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/papaparse": "^5.5.2",
    "@types/react-big-calendar": "^1.16.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "heic-convert": "^2.1.0",
    "jpeg-js": "^0.4.4",
    "lucide-react": "^0.563.0",
    "moment": "^2.30.1",
    "p-limit": "^3.1.0",
    "papaparse": "^5.5.3",
    "react-big-calendar": "^1.19.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-image-crop": "^11.0.10",
    "react-resizable-panels": "^4.6.0",
    "react-virtuoso": "^4.18.1",
    "sharp": "^0.33.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
