#!/usr/bin/env bash
set -euo pipefail

branch="$(git symbolic-ref --quiet --short HEAD || true)"

if [[ "${ALLOW_MAIN_COMMIT:-}" == "1" ]]; then
  exit 0
fi

case "$branch" in
  main|master)
    echo "[git-governance] Blocked: direct commit on '$branch'."
    echo "[git-governance] Create a feature branch first:"
    echo "  git checkout -b codex/<scope>-<goal>"
    echo "[git-governance] If this is an emergency and you understand the risk:"
    echo "  ALLOW_MAIN_COMMIT=1 git commit ..."
    exit 1
    ;;
esac

exit 0
