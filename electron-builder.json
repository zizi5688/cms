{
  "appId": "com.supercms.app",
  "productName": "Super CMS",
  "directories": {
    "buildResources": "build",
    "output": "release"
  },
  "files": [
    "!**/.vscode/*",
    "!{.claude,.github,.githooks,.trae,.worktrees}{,/**/*}",
    "!src/*",
    "!{AI_Tools,build,dist,docs,outputs,python,release,scripts,skills}{,/**/*}",
    "!{AGENTS.md,components.json,cms.sqlite,cms_engine.spec,.gitmessage.txt}",
    "!electron.vite.config.{js,ts,mjs,cjs}",
    "!{.eslintcache,eslint.config.mjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}",
    "!{.env,.env.*,.npmrc,pnpm-lock.yaml}",
    "!{tsconfig.json,tsconfig.node.json,tsconfig.web.json}"
  ],
  "extraResources": [
    {
      "from": "dist",
      "to": ".",
      "filter": ["cms_engine", "cms_engine.exe"]
    },
    {
      "from": "dist/realesrgan",
      "to": "realesrgan"
    }
  ],
  "asarUnpack": [
    "resources/**",
    "**/node_modules/sharp/**",
    "**/node_modules/@img/**",
    "**/node_modules/better-sqlite3/**",
    "**/node_modules/ffmpeg-static/**",
    "**/node_modules/ffprobe-static/**"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "executableName": "super-cms"
  },
  "nsis": {
    "artifactName": "${name}-${version}-${arch}-setup.${ext}",
    "shortcutName": "${productName}",
    "uninstallDisplayName": "${productName}",
    "createDesktopShortcut": "always"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "build/icon.icns",
    "identity": null,
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": [
      {
        "NSCameraUsageDescription": "Application requests access to the device's camera.",
        "NSMicrophoneUsageDescription": "Application requests access to the device's microphone.",
        "NSDocumentsFolderUsageDescription": "Application requests access to the user's Documents folder.",
        "NSDownloadsFolderUsageDescription": "Application requests access to the user's Downloads folder."
      }
    ],
    "notarize": false
  },
  "dmg": {
    "artifactName": "${name}-${version}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "snap", "deb"],
    "maintainer": "electronjs.org",
    "category": "Utility"
  },
  "appImage": {
    "artifactName": "${name}-${version}.${ext}"
  },
  "npmRebuild": false,
  "publish": [
    {
      "provider": "github",
      "owner": "zizi5688",
      "repo": "cms",
      "releaseType": "release"
    }
  ],
  "electronDownload": {
    "mirror": "https://npmmirror.com/mirrors/electron/"
  },
  "afterPack": "scripts/after-pack-runtime-deps.cjs"
}
